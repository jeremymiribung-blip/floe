{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Floe",
  "version": "0.1.0",
  "identifier": "dev.floe.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Floe",
        "width": 900,
        "height": 680,
        "resizable": true,
        "visible": false
      },
      {
        "label": "recording-bubble",
        "title": "",
        "url": "index.html",
        "width": 170,
        "height": 48,
        "minWidth": 170,
        "minHeight": 48,
        "maxWidth": 170,
        "maxHeight": 48,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      // CSP: 'unsafe-inline' on style-src is required by the frontend
      // framework (React/Vite). All external resource loading is blocked
      // intentionally for security.
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "deb", "appimage", "rpm"],
    "publisher": "Floe Contributors",
    "category": "Productivity",
    "shortDescription": "Push-to-talk transcription with Groq",
    "longDescription": "Hold the hotkey, speak, release – Floe transcribes your speech with Groq Whisper Turbo and cleans the transcript with Groq Llama 3.3 70B Versatile, then pastes the result where your cursor is.",
    "homepage": "https://github.com/anomalyco/floe",
    "licenseFile": "../LICENSE",
    "copyright": "Copyright (c) 2026 Floe Contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English", "German"],
        "displayLanguageSelector": true
      },
      "wix": {
        "language": ["en-US", "de-DE"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "providerShortName": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "libasound2"
        ],
        "section": "utils",
        "priority": "optional",
        "changelog": "../CHANGELOG.md"
      }
    }
  }
}
